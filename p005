#include <iostream>
#include <vector>

using namespace std;

int main() {
    int tmp;
    int N, M;

    cin >> N >> M;
    vector<int> S(N + 1);
    vector<int> L(M);
    for (int i = 1; i <= N; i++) {
        cin >> tmp;
        S[i] = (tmp + S[i - 1]) % M;
        L[S[i]]++;
    }

    long long count = 0;
    count += L[0];
    for (int i = 0; i < M; i++) {
        if (L[i] > 0) count += 1LL * L[i] * (L[i] - 1) / 2;
    }
    cout << count << '\n';
}
