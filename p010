#include <iostream>
#include <deque>

using namespace std;

int main() {
    int num, len;
    deque<NODE> dq;
    cin >> num >> len;

    for (int i = 0; i < num; i++) {
        int now;
        cin >> now;

        while (!dq.empty() && now <= dq.back().data) {
            dq.pop_back();
        }
        dq.push_back({ i, now });

        while (!dq.empty() && i - len >= dq.front().index) {
            dq.pop_front();
        }
        cout << dq.front().data;
    }
}
